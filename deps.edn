{;; ============================================================================
 ;; embabel-clj — BIBLIOTECA data-driven sobre o Embabel (agentes GOAP na JVM).
 ;;
 ;; A raiz deste repo é a biblioteca (consumível via :local/root, git dep ou
 ;; jar instalado). Os apps de exemplo vivem em examples/.
 ;;
 ;; 100% Clojure-fonte: a classe @SpringBootApplication do boot é uma gen-class
 ;; anotada via metadata (embabel-clj.boot-class), compilada SOB DEMANDA em
 ;; runtime pelo platform/start! — sem javac, sem prep, sem target/classes.
 ;; ============================================================================
 :paths ["src"]

 :mvn/repos
 {"central"           {:url "https://repo1.maven.org/maven2/"}
  "clojars"           {:url "https://repo.clojars.org/"}
  ;; Obrigatório: dependências transitivas do Embabel/Spring AI (mcp-bom)
  ;; vivem em milestones. Consumidores precisam repetir este repo no próprio
  ;; deps.edn (tools.deps NÃO herda :mvn/repos de dependências).
  "spring-milestones" {:url "https://repo.spring.io/milestone"}}

 :deps
 {org.clojure/clojure                     {:mvn/version "1.12.1"}
  ;; Traz embabel-agent-api + autoconfigure (o bean AgentPlatform).
  com.embabel.agent/embabel-agent-starter {:mvn/version "0.4.0"}
  ;; Schemas-como-dado: valida a própria API da lib E a saída do LLM.
  metosin/malli                           {:mvn/version "0.16.4"}}

 :aliases
 {;; build da biblioteca: clojure -T:build jar | install | clean
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.5"}}
          :ns-default build}

  ;; Provider LLM OpenAI-compatível (OpenRouter/OpenAI). A lib NÃO fixa
  ;; provider; adicione este alias (ou o starter equivalente) no seu app.
  :openai {:extra-deps {com.embabel.agent/embabel-agent-starter-openai
                        {:mvn/version "0.4.0"}}}

  :dev {:extra-paths ["examples/nature/src" "examples/nature/resources"]
        :extra-deps  {nrepl/nrepl {:mvn/version "1.3.1"}
                      com.embabel.agent/embabel-agent-starter-openai
                      {:mvn/version "0.4.0"}}}

  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]
         :exec-fn     cognitect.test-runner.api/test}}}
