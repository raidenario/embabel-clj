{:paths ["src/main/clojure" "src/main/resources" "target/classes"]

 :mvn/repos
 {"central"           {:url "https://repo1.maven.org/maven2/"}
  "clojars"           {:url "https://repo.clojars.org/"}
  "spring-milestones" {:url "https://repo.spring.io/milestone"}}

 :deps
 {org.clojure/clojure                            {:mvn/version "1.12.1"}
  com.embabel.agent/embabel-agent-starter        {:mvn/version "0.4.0"}
  com.embabel.agent/embabel-agent-starter-openai {:mvn/version "0.4.0"}
  nrepl/nrepl                                     {:mvn/version "1.3.1"}
  metosin/malli                                   {:mvn/version "0.16.4"}
  cheshire/cheshire                               {:mvn/version "5.13.0"}}

 :aliases
 {:run {:main-opts ["-m" "embabel-clj.main"]}

  ;; Testes das funcoes PURAS de reconcile (snapshot->conditions / classify-error).
  ;; Nao precisa do Spring/Embabel: roda so a ns de teste, que require apenas
  ;; clojure.string (transitivamente via reconcile). Para evitar carregar o
  ;; import de classes Embabel ao testar, o teste re-declara as fns puras OU
  ;; usa um classpath com as classes; aqui rodamos com o classpath completo.
  :test {:extra-paths ["test"]
         :main-opts   ["-m" "embabel-clj.reconcile-test"]}}}
